<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">




        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/item_card_view"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardPreventCornerOverlap="true"
            android:padding="0dp"
            card_view:cardBackgroundColor="@android:color/transparent"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    >

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.8"
                            android:hint="Date">


                            <EditText
                                android:id="@+id/tv_date"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:maxLines="1"
                                android:lines="1"
                                android:layout_marginBottom="2dp"
                                android:layout_marginEnd="8dp"
                                android:layout_marginStart="8dp"
                                android:layout_marginTop="2dp"
                                android:textSize="18sp"
                                android:inputType="date"
                                />

                        </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:id="@+id/ll_week_switc_container"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1.3"
                        android:orientation="vertical"
                        android:layout_gravity="center_horizontal|top"
                        android:gravity="center_horizontal|top">


                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Week"
                            android:lines="1"
                            android:textSize="12dp"
                            android:gravity="center"
                            android:layout_gravity="bottom"/>

                        <Switch
                            android:id="@+id/switch_week"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"/>

                    </LinearLayout>



                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_count_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Days count"
                        >

                        <EditText
                            android:id="@+id/tv_count_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="1"
                            android:lines="1"
                            android:layout_marginBottom="2dp"
                            android:layout_marginEnd="8dp"
                            android:layout_marginStart="8dp"
                            android:layout_marginTop="2dp"
                            android:textSize="18sp"
                            android:gravity="right"
                            android:inputType="number"/>

                    </com.google.android.material.textfield.TextInputLayout>



                </LinearLayout>

                <include layout="@layout/report_raiting_bar_container"></include>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_report_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Report text">

                    <EditText
                        android:id="@+id/tv_report_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="2"
                        android:gravity="bottom"
                        android:layout_margin="8dp"
                        android:focusedByDefault="true"
                        />

                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/ll_action_button"
                    android:gravity="end"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/btn_cancel"
                        android:text="CANCEL"
                        android:textStyle="bold"
                        android:textColor="@color/colorDialogOnSurfaceVariant"
                        android:textSize="14sp"
                        android:padding="12dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"/>


                    <TextView
                        android:layout_marginStart="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/btn_action"
                        android:text="ADD"
                        android:textStyle="bold"
                        android:textColor="@color/colorAccent"
                        android:textSize="14sp"
                        android:padding="12dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"/>


                </LinearLayout>


            </LinearLayout>



        </androidx.cardview.widget.CardView>

    </ScrollView>
</LinearLayout>







