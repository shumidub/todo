<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="4dp">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/section_name_layout"
        style="@style/Widget.App.TextInputLayout.Dialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:counterEnabled="true"
        app:counterMaxLength="40"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:hint="Section name">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/section_name"
            style="@style/Widget.App.EditText.Dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusedByDefault="true"
            android:imeOptions="actionDone"
            android:inputType="textCapSentences"
            android:maxLength="40"
            android:maxLines="1"/>

    </com.google.android.material.textfield.TextInputLayout>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/section_collapsed_default"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Collapsed by default"/>

</LinearLayout>
