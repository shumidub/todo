<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="4dp">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.App.TextInputLayout.Dialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Folder name">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/name"
            style="@style/Widget.App.EditText.Dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusedByDefault="true"
            android:imeOptions="actionDone"
            android:inputType="textCapSentences"
            android:maxLines="1"/>

    </com.google.android.material.textfield.TextInputLayout>

    <CheckBox
        android:id="@+id/checkboxIsDaily"
        style="@style/Widget.App.CheckBox.Dialog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Daily"
        android:checked="true"/>

    <TextView
        android:id="@+id/labelTabColor"
        style="@style/TextAppearance.App.Dialog.LabelSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/tab_color"/>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/tabColorToggleGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabColorGreen"
            style="@style/Widget.App.Button.TabColorSwatch.Green"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_color_green"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabColorBlue"
            style="@style/Widget.App.Button.TabColorSwatch.Blue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_color_blue"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabColorYellow"
            style="@style/Widget.App.Button.TabColorSwatch.Yellow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_color_yellow"/>

    </com.google.android.material.button.MaterialButtonToggleGroup>

</LinearLayout>
