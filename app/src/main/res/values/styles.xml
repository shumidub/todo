<resources>

    <!-- Base application theme. Bridge variant lets us keep AppCompat widgets while picking up Material features. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.DarkActionBar.Bridge">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:actionBarSize">54dp</item>
        <item name="android:actionModeBackground">@color/colorActionMode</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.App.AlertDialog</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog</item>
        <!-- Match system bar tint to action bar / panel chrome. -->
        <item name="android:windowBackground">@color/colorPrimaryDark</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:navigationBarColor">@color/colorPrimaryDark</item>
    </style>

<!-- AppCompat AlertDialog overlay — kept so legacy AlertDialog.Builder uses our colors. -->
    <style name="ThemeOverlay.App.AlertDialog" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog_rounded</item>
        <item name="android:windowMinWidthMajor">88%</item>
        <item name="android:windowMinWidthMinor">88%</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:textColorPrimary">@color/colorDialogOnSurface</item>
        <item name="android:textColor">@color/colorDialogOnSurface</item>
        <item name="android:colorBackground">@color/colorDialogSurface</item>
    </style>

    <!-- Material AlertDialog overlay — used by MaterialAlertDialogBuilder. -->
    <style name="ThemeOverlay.App.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.App.Dialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.App.Dialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.App.Button.Dialog.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.App.Button.Dialog.Negative</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.App.Button.Dialog.Neutral</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.App.Dialog</item>
        <item name="dialogCornerRadius">24dp</item>
        <item name="colorSurface">@color/colorDialogSurface</item>
        <item name="colorOnSurface">@color/colorDialogOnSurface</item>
        <item name="android:textColorPrimary">@color/colorDialogOnSurface</item>
        <item name="android:textColorSecondary">@color/colorDialogOnSurfaceVariant</item>
        <item name="android:colorBackground">@color/colorDialogSurface</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowMinWidthMajor">88%</item>
        <item name="android:windowMinWidthMinor">88%</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="TextAppearance.App.Dialog.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/colorDialogOnSurface</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.005</item>
    </style>

    <style name="TextAppearance.App.Dialog.Body" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/colorDialogOnSurfaceVariant</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingMultiplier">1.15</item>
    </style>

    <style name="Widget.App.Button.Dialog.Positive" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/colorAccent</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.025</item>
        <item name="rippleColor">@color/colorAccent</item>
    </style>

    <style name="Widget.App.Button.Dialog.Negative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/colorDialogOnSurfaceVariant</item>
        <item name="android:letterSpacing">0.025</item>
    </style>

    <style name="Widget.App.Button.Dialog.Neutral" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/colorDialogOnSurfaceVariant</item>
        <item name="android:letterSpacing">0.025</item>
    </style>

    <!-- Floating-label EditText used inside dialogs. -->
    <style name="Widget.App.TextInputLayout.Dialog" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/colorAccent</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/colorAccent</item>
        <item name="android:textColorHint">@color/colorDialogOnSurfaceVariant</item>
    </style>

    <style name="Widget.App.EditText.Dialog" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/colorDialogOnSurface</item>
        <item name="android:textColorHint">@color/colorDialogOnSurfaceVariant</item>
        <item name="android:textCursorDrawable">@null</item>
    </style>

    <style name="Widget.App.CheckBox.Dialog" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:textColor">@color/colorDialogOnSurface</item>
        <item name="buttonTint">@color/colorAccent</item>
    </style>

</resources>


